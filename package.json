{
  "name": "kin-ocr",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "fix:eslint": "eslint --fix --config=eslint.config.mjs",
    "fix:prettier": "prettier --write './**/*.{js,json,ts,md,html,css,scss}'",
    "format": "run-s --continue-on-error fix:*",
    "lint": "run-s --continue-on-error lint:*",
    "lint:cspell": "cspell \"./**/*.{js,json,ts,md,html,css,scss}\" --no-progress",
    "lint:eslint": "eslint --config=eslint.config.mjs",
    "lint:prettier": "prettier --check './**/*.{js,json,ts,md,html,css,scss}'",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --browsers=ChromeHeadlessCI --no-watch"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.16",
    "@angular/common": "^20.3.16",
    "@angular/compiler": "^20.3.16",
    "@angular/core": "^20.3.16",
    "@angular/forms": "^20.3.16",
    "@angular/platform-browser": "^20.3.16",
    "@angular/platform-browser-dynamic": "^20.3.16",
    "@angular/router": "^20.3.16",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.17",
    "@angular/cli": "^20.3.17",
    "@angular/compiler-cli": "^20.3.16",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/jasmine": "~5.1.0",
    "cspell": "^9.7.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine-core": "^5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.56.1"
  }
}
